# Discord Developer Portal > Bot Token
DISCORD_TOKEN=여기에_봇_토큰

# Discord Developer Portal > General Information > Application ID
CLIENT_ID=여기에_애플리케이션_ID

# 테스트할 서버 ID. 빠른 명령어 등록용
GUILD_ID=여기에_서버_ID

# MongoDB Atlas 연결 주소
MONGODB_URI=mongodb+srv://아이디:비밀번호@클러스터주소/yukiha?retryWrites=true&w=majority

# 아래 값들은 .env에 넣지 않습니다.
# 관리자 역할, 티켓 카테고리, 로그 채널은 디스코드에서 /티켓설정 명령어로 지정하세요.
